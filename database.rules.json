{
  "rules": {
    "users": {
      ".indexOn": ["score"],
      ".read": true,
      "$uid": {
        ".write": "auth != null && auth.uid === $uid"
      }
    },
    "pendingReferrals": {
      "$referrerId": {
        ".read": "auth != null && auth.uid === $referrerId",
        "$newUserId": {
           ".write": "auth != null && auth.uid === $newUserId",
           ".validate": "newData.exists()"
        }
      }
    },
    "leaderboard": {
       ".read": true
    }
  }
}