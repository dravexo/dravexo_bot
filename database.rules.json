{
  "rules": {
    "users": {
      "$uid": {
        
        ".read": "$uid === auth.uid",
        ".write": "$uid === auth.uid",
        
        
        "score": {
          ".validate": "newData.isNumber() && newData.val() >= data.val() && (newData.val() - data.val() < 1000)"
        },
        "energy": {
          ".validate": "newData.isNumber() && newData.val() >= 0 && newData.val() <= 500"
        },
         
        "referredBy": {
          ".validate": "newData.isString() && !data.exists()"
        },
        
        "transactions": {
          "$txId": {
            ".validate": "newData.hasChildren(['type', 'amount', 'date']) && newData.child('type').isString() && newData.child('amount').isNumber() && newData.child('date').isNumber()"
          }
        }
      }
    }
  }
}
